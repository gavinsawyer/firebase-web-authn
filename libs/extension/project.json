{
  "$schema":     "../../node_modules/nx/schemas/project-schema.json",

  "name":        "extension",
  "projectType": "library",
  "sourceRoot":  "libs/extension/src",

  "targets":     {
    "build":              {
      "dependsOn": [ "install--extension" ],
      "executor":  "nx:noop"
    },
    "esbuild":            {
      "dependsOn": [ "lint" ],
      "executor":  "@nx/esbuild:esbuild",
      "options":   {
        "assets":         [
          {
            "glob":   "CHANGELOG.md",
            "input":  "libs/extension",
            "output": "."
          },
          {
            "glob":   "extension.yaml",
            "input":  "libs/extension",
            "output": "."
          },
          {
            "glob":   "icon.png",
            "input":  "libs/extension",
            "output": "."
          },
          {
            "glob":   "package.json",
            "input":  "libs/extension/src",
            "output": "./src"
          },
          {
            "glob":   "POSTINSTALL.md",
            "input":  "libs/extension",
            "output": "."
          },
          {
            "glob":   "PREINSTALL.md",
            "input":  "libs/extension",
            "output": "."
          },
          {
            "glob":   "README.md",
            "input":  "libs/extension",
            "output": "."
          }
        ],
        "esbuildOptions": {
          "banner": {
            "css": "/*!\n / Copyright © 2026 Gavin William Sawyer. All rights reserved.\n /\n",
            "js":  "/*\n * Copyright © 2026 Gavin William Sawyer. All rights reserved.\n */\n"
          }
        },
        "main":           "libs/extension/src/lib/main.ts",
        "metafile":       true,
        "minify":         true,
        "outputFileName": "src/main.js",
        "outputPath":     "dist/libs/extension",
        "platform":       "node",
        "splitting":      true,
        "treeShaking":    true,
        "tsConfig":       "libs/extension/tsconfig.lib.json"
      },
      "outputs":   [ "{workspaceRoot}/dist/libs/extension" ]
    },
    "install--extension": {
      "dependsOn": [ "esbuild" ],
      "executor":  "nx:run-commands",
      "options":   {
        "command": "npm i --package-lock-only && cd src && npm i --package-lock-only",
        "cwd":     "dist/libs/extension"
      }
    },
    "lint":               {
      "executor": "@nx/eslint:lint",
      "options":  {
        "lintFilePatterns": [
          "libs/extension/package.json",
          "libs/extension/src/**/*.ts"
        ]
      }
    }
  }
}
