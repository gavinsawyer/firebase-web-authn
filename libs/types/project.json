{
  "$schema":     "../../node_modules/nx/schemas/project-schema.json",

  "name":        "types",
  "projectType": "library",
  "sourceRoot":  "libs/types/src",

  "targets":     {
    "build": {
      "dependsOn": [ "lint" ],
      "executor":  "@nx/esbuild:esbuild",
      "options":   {
        "assets":         [
          {
            "glob":   "README.md",
            "input":  "libs/types",
            "output": "."
          }
        ],
        "declaration":    true,
        "esbuildOptions": {
          "banner": {
            "css": "/*!\n / Copyright © 2026 Gavin William Sawyer. All rights reserved.\n /\n",
            "js":  "/*\n * Copyright © 2026 Gavin William Sawyer. All rights reserved.\n */\n"
          }
        },
        "external":       [ "@firebase-web-authn/*" ],
        "main":           "libs/types/src/index.ts",
        "metafile":       true,
        "minify":         true,
        "outputPath":     "dist/libs/types",
        "platform":       "neutral",
        "splitting":      true,
        "treeShaking":    true,
        "tsConfig":       "libs/types/tsconfig.lib.json"
      },
      "outputs":   [ "{workspaceRoot}/dist/libs/types" ]
    },
    "lint":  {
      "executor": "@nx/eslint:lint",
      "options":  {
        "lintFilePatterns": [
          "libs/types/package.json",
          "libs/types/src/**/*.ts"
        ]
      }
    }
  }
}
